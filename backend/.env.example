# WordPress DB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=wordpress
DB_PASSWORD=your_db_password
DB_NAME=wordpress

# WordPress table prefix (default is wp_)
WP_TABLE_PREFIX=wp_

# JWT settings — generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Media uploads directory (absolute path or relative to backend/)
UPLOAD_DIR=./uploads

# WordPress site URL (used for generating attachment GUIDs)
SITE_URL=http://localhost:8000
